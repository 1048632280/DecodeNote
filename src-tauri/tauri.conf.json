{
  "$schema": "https://raw.githubusercontent.com/nicegraf/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DecodeNote",
  "version": "0.1.0",
  "identifier": "com.decodenote.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DecodeNote",
        "width": 900,
        "height": 650,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
